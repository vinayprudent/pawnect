@model List<BookingConfirmViewModel>
@{
    ViewData["Title"] = "Upcoming Appointments";
}

<div class="appointments-page">
    <h2 class="mb-4"><i class="bi bi-calendar-check me-2"></i>Upcoming Appointments</h2>
    @if (Model != null && Model.Any())
    {
        <div class="appointment-list">
            @foreach (var b in Model)
            {
                <div class="card vet-card-pawnect mb-3">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="card-title mb-1">@b.VetName</h5>
                                <p class="card-text small text-muted mb-1">@b.ClinicName</p>
                                <p class="card-text small mb-1">
                                    <i class="bi bi-calendar3 me-1"></i>@b.SlotDate @b.SlotTime · <span class="badge bg-success">@b.Status</span>
                                </p>
                                <p class="card-text small mb-0">Pet: @b.PetName</p>
                            </div>
                            <div class="col-auto">
                                <a asp-controller="Consultations" asp-action="Details" asp-route-id="@b.AppointmentId" class="btn btn-pawnect btn-sm me-1"><i class="bi bi-clipboard2-pulse me-1"></i>View consultation</a>
                                @{
                                    var ratedIds = ViewBag.RatedBookingIds as HashSet<string> ?? new HashSet<string>();
                                    var canRate = (b.Status == "Completed" || b.Status == "Closed") && b.AppointmentId.HasValue && !ratedIds.Contains(b.AppointmentId.Value.ToString());
                                }
                                @if (canRate)
                                {
                                    <a asp-controller="Consultations" asp-action="Details" asp-route-id="@b.AppointmentId" class="btn btn-outline-warning btn-sm me-1"><i class="bi bi-star me-1"></i>Rate vet</a>
                                }
                                @if (b.AppointmentId.HasValue)
                                {
                                    <a asp-action="Reschedule" asp-route-appointmentId="@b.AppointmentId" class="btn btn-outline-secondary btn-sm me-1">Reschedule</a>
                                    <form asp-action="Cancel" method="post" class="d-inline" onsubmit="return confirm('Cancel this appointment?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="appointmentId" value="@b.AppointmentId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-calendar-x display-4 text-muted"></i>
                <h5 class="mt-3">No upcoming appointments</h5>
                <p class="text-muted">Book an in-clinic appointment from Find Vets.</p>
                <a asp-controller="Vets" asp-action="Index" class="btn btn-pawnect">Find Vets</a>
            </div>
        </div>
    }
</div>

<style>
    .vet-card-pawnect { border-radius: 12px; border: 1px solid var(--border); }
</style>
