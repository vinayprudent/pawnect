@model RescheduleViewModel
@{
    ViewData["Title"] = "Reschedule Appointment";
    var booking = Model.Booking;
}

<div class="reschedule-page">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Upcoming Appointments</a></li>
            <li class="breadcrumb-item active">Reschedule</li>
        </ol>
    </nav>

    <div class="card mb-3">
        <div class="card-body py-2">
            <strong>@booking.VetName</strong> · @booking.ClinicName · Pet: @booking.PetName<br />
            <span class="text-muted small">Current slot: @booking.SlotDate @booking.SlotTime</span>
        </div>
    </div>

    <h5 class="mb-3">Select new date & time</h5>
    <p class="text-muted small mb-3">Green = Available</p>
    <div class="slot-grid">
        @foreach (var slot in Model.Slots)
        {
            if (slot.IsAvailable)
            {
                <form asp-action="Reschedule" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="appointmentId" value="@booking.AppointmentId" />
                    <input type="hidden" name="slotDate" value="@slot.Date" />
                    <input type="hidden" name="slotTime" value="@slot.Time" />
                    <button type="submit" class="slot-pill slot-available border-0">@slot.DisplayText</button>
                </form>
            }
            else
            {
                <span class="slot-pill slot-booked">@slot.DisplayText</span>
            }
        }
    </div>
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Appointments</a>
    </div>
</div>

<style>
    .slot-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .slot-pill {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 0.9rem;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--border, #dee2e6);
        cursor: pointer;
    }
    .slot-available { background: rgba(22,122,119,0.1); border-color: #167a77; color: #167a77; }
    .slot-available:hover { background: rgba(22,122,119,0.2); }
    .slot-booked { background: #e9ecef; color: #6c757d; cursor: not-allowed; }
</style>
