@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <img src="~/images/PawNect Logo.png" alt="PawNect" class="auth-logo" />
            <h1 class="auth-title">Sign in to PawNect</h1>
            <p class="auth-sub">Enter your registered email or mobile number to receive an OTP.</p>
        </div>
        <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="EmailOrMobile" class="form-label"></label>
                <input asp-for="EmailOrMobile" class="form-control form-control-pawnect" placeholder="you@example.com or 9876543210" autocomplete="username" />
                <span asp-validation-for="EmailOrMobile" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-pawnect w-100 mb-2">Sign in</button>
            <p class="text-center small text-muted mb-0">
                Pet parent? <a asp-action="Register" class="text-teal fw-medium">Register</a> here. Vet and Lab registration is done by Admin.
            </p>
        </form>
    </div>
</div>

@section Styles {
<style>
    .auth-page { max-width: 440px; margin: 2rem auto; }
    .auth-card {
        background: rgba(255,255,255,0.96);
        border-radius: 18px;
        padding: 2rem;
        border: 1px solid var(--border);
        box-shadow: 0 18px 40px rgba(15,47,55,0.15);
    }
    .auth-header { text-align: center; margin-bottom: 1.5rem; }
    .auth-logo { height: 48px; margin-bottom: 0.75rem; }
    .auth-title { font-size: 1.35rem; font-weight: 700; color: var(--teal); margin-bottom: 0.25rem; }
    .auth-sub { font-size: 0.9rem; color: #6c7880; }
    .form-control-pawnect:focus {
        border-color: var(--teal);
        box-shadow: 0 0 0 0.2rem rgba(22,122,119,0.2);
    }
    .text-teal { color: var(--teal); }
</style>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
