@model VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <img src="~/images/PawNect Logo.png" alt="PawNect" class="auth-logo" />
            <h1 class="auth-title">Verify OTP</h1>
            <p class="auth-sub">Enter the OTP sent to @Model.MaskedDestination</p>
        </div>
        <form asp-action="VerifyOtp" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="ChallengeId" />
            <input type="hidden" asp-for="Purpose" />
            <input type="hidden" asp-for="MaskedDestination" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3">
                <label asp-for="OtpCode" class="form-label">OTP Code</label>
                <input asp-for="OtpCode" class="form-control form-control-pawnect" placeholder="Enter OTP" autocomplete="one-time-code" />
                <span asp-validation-for="OtpCode" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-pawnect w-100 mb-2">Verify</button>
        </form>

        <form asp-action="ResendOtp" method="post">
            <input type="hidden" asp-for="ChallengeId" />
            <input type="hidden" asp-for="Purpose" />
            <input type="hidden" asp-for="MaskedDestination" />
            <input type="hidden" asp-for="ReturnUrl" />
            <button type="submit" class="btn btn-outline-secondary w-100">Resend OTP</button>
        </form>
    </div>
</div>

@section Styles {
<style>
    .auth-page { max-width: 420px; margin: 2rem auto; }
    .auth-card {
        background: rgba(255,255,255,0.96);
        border-radius: 18px;
        padding: 2rem;
        border: 1px solid var(--border);
        box-shadow: 0 18px 40px rgba(15,47,55,0.15);
    }
    .auth-header { text-align: center; margin-bottom: 1.5rem; }
    .auth-logo { height: 48px; margin-bottom: 0.75rem; }
    .auth-title { font-size: 1.35rem; font-weight: 700; color: var(--teal); margin-bottom: 0.25rem; }
    .auth-sub { font-size: 0.9rem; color: #6c7880; }
    .form-control-pawnect:focus {
        border-color: var(--teal);
        box-shadow: 0 0 0 0.2rem rgba(22,122,119,0.2);
    }
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
