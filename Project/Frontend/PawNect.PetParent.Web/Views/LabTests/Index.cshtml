@model LabTestLandingViewModel
@{
    ViewData["Title"] = "Lab Tests";
}

<div class="lab-landing-page">
    <div class="alert alert-info lab-guardrail mb-4" role="alert">
        <i class="bi bi-info-circle me-2"></i><strong>Important:</strong> Preventive tests are for routine health monitoring only. Illness diagnostics require vet consultation.
    </div>
    <div class="lab-hero mb-4">
        <span class="badge-hero">Preventive health</span>
        <h1 class="hero-title">Lab tests &amp; home collection</h1>
        <p class="hero-sub">
            Choose preventive health tests, wellness packages, or individual tests. Home collection or in-clinic – PawNect assigns the lab for you.
        </p>
    </div>

    <div class="lab-sections">
        @if (Model.ShowPreventiveHealthTests)
        {
            <section class="lab-section card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-2"><i class="bi bi-shield-check text-teal me-2"></i>Preventive Health Tests</h2>
                    <p class="text-muted small mb-3">Routine screening to keep your pet healthy. Packages and individual tests available.</p>
                    <a asp-action="SelectTestType" class="btn btn-pawnect btn-sm">Browse tests</a>
                </div>
            </section>
        }
        @if (Model.ShowWellnessPackages)
        {
            <section class="lab-section card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-2"><i class="bi bi-box-seam text-teal me-2"></i>Wellness Packages</h2>
                    <p class="text-muted small mb-3">Basic Health Check, Annual Wellness, Senior Panel – curated panels at one price.</p>
                    <a asp-action="SelectTestType" class="btn btn-pawnect btn-sm">View packages</a>
                </div>
            </section>
        }
        @if (Model.ShowIndividualTests)
        {
            <section class="lab-section card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-2"><i class="bi bi-droplet text-teal me-2"></i>Individual Tests</h2>
                    <p class="text-muted small mb-3">CBC, LFT, KFT, Thyroid – order single tests as needed.</p>
                    <a asp-action="SelectTestType" class="btn btn-pawnect btn-sm">View individual tests</a>
                </div>
            </section>
        }
    </div>

    @if (SessionHelper.IsAuthenticated(Context.Session))
    {
        <div class="mt-4 pt-3 border-top">
            <a asp-action="OrderStatus" class="btn btn-outline-pawnect btn-sm"><i class="bi bi-list-ul me-1"></i>My lab orders</a>
        </div>
    }
</div>

<style>
    .lab-landing-page { max-width: 720px; margin: 0 auto; }
    .lab-guardrail { border-radius: 10px; border-left: 4px solid var(--teal, #167a77); }
    .lab-hero {
        padding: 1.5rem;
        border-radius: 14px;
        background: linear-gradient(135deg, #e5fbf5 0, #ffffff 50%, #dff4f0 100%);
        border: 1px solid rgba(215,226,230,0.8);
        text-align: center;
    }
    .badge-hero {
        display: inline-block;
        font-size: 0.7rem;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(22,122,119,0.08);
        color: #145a56;
        margin-bottom: 0.5rem;
    }
    .hero-title { font-size: 1.5rem; font-weight: 700; color: #12333a; margin-bottom: 0.5rem; }
    .hero-sub { font-size: 0.9rem; color: #53616a; margin-bottom: 0; }
    .lab-section .card-body { padding: 1.25rem; }
    .text-teal { color: var(--teal); }
</style>
