@model LabTestSelectTypeViewModel
@{
    ViewData["Title"] = "Select test type";
}

<div class="lab-select-type-page">
    <div class="alert alert-info lab-guardrail mb-4" role="alert">
        <i class="bi bi-info-circle me-2"></i>Preventive tests are for routine health monitoring only. Illness diagnostics require vet consultation.
    </div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Lab tests</a></li>
            <li class="breadcrumb-item active">Select test</li>
        </ol>
    </nav>
    <h2 class="mb-4"><i class="bi bi-droplet me-2"></i>Select test type</h2>

    <h5 class="mt-4 mb-2">Packages</h5>
    <p class="text-muted small mb-3">Curated panels – one price, multiple tests.</p>
    <div class="row g-3 mb-4">
        @foreach (var pkg in Model.Packages)
        {
            <div class="col-md-4">
                <div class="card h-100 lab-test-card">
                    <div class="card-body">
                        <h6 class="card-title">@pkg.Name</h6>
                        @if (!string.IsNullOrEmpty(pkg.Description))
                        {
                            <p class="card-text small text-muted">@pkg.Description</p>
                        }
                        <p class="mb-1 small"><strong>Sample:</strong> @pkg.SampleType</p>
                        <p class="mb-2 small">Includes: @string.Join(", ", pkg.TestsIncluded)</p>
                        <p class="mb-2"><strong class="text-teal">₹@pkg.Price.ToString("N0")</strong></p>
                        <a asp-action="SelectPetAndCollection" asp-route-testId="@pkg.Id" asp-route-testType="package" class="btn btn-pawnect btn-sm w-100">Select</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <h5 class="mt-4 mb-2">Individual tests</h5>
    <p class="text-muted small mb-3">Order single tests as needed.</p>
    <div class="row g-3">
        @foreach (var test in Model.IndividualTests)
        {
            <div class="col-md-3 col-6">
                <div class="card h-100 lab-test-card">
                    <div class="card-body">
                        <h6 class="card-title">@test.Name</h6>
                        @if (!string.IsNullOrEmpty(test.FullName) && test.FullName != test.Name)
                        {
                            <p class="card-text small text-muted mb-1">@test.FullName</p>
                        }
                        <p class="mb-1 small"><strong>Sample:</strong> @test.SampleType</p>
                        <p class="mb-2"><strong class="text-teal">₹@test.Price.ToString("N0")</strong></p>
                        <a asp-action="SelectPetAndCollection" asp-route-testId="@test.Id" asp-route-testType="individual" class="btn btn-pawnect btn-sm w-100">Select</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to lab tests</a>
    </div>
</div>

<style>
    .lab-test-card { border-radius: 12px; border: 1px solid var(--border); }
    .lab-guardrail { border-radius: 10px; border-left: 4px solid var(--teal, #167a77); }
    .text-teal { color: var(--teal); }
</style>
