@model IReadOnlyList<LabOrderListItemViewModel>
@{
    ViewData["Title"] = "My lab orders";
}

<div class="lab-order-status-page">
    <h2 class="mb-4"><i class="bi bi-list-ul me-2"></i>My lab orders</h2>
    <p class="text-muted small mb-4">Status flow: Ordered → Sample Scheduled → Sample Collected → Processing → Report Uploaded</p>

    @if (Model != null && Model.Any())
    {
        <div class="lab-order-list">
            @foreach (var o in Model)
            {
                <div class="card vet-card-pawnect mb-3">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="card-title mb-1">@o.TestDisplayName</h5>
                                <p class="card-text small text-muted mb-1">Order ID: @o.OrderId</p>
                                <p class="card-text small mb-1">
                                    <i class="bi bi-heart me-1"></i>@o.PetName
                                    <span class="badge lab-status-badge ms-1">@o.Status</span>
                                </p>
                                <p class="card-text small mb-0">@(o.CollectionType == "Home" ? "Home collection" : "In-clinic") · ₹@o.Price.ToString("N0") · @o.OrderedAt</p>
                            </div>
                            <div class="col-auto">
                                @if (o.HasReport)
                                {
                                    <a asp-action="Report" asp-route-orderId="@o.OrderId" class="btn btn-pawnect btn-sm">
                                        <i class="bi bi-file-earmark-pdf me-1"></i>View report
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="OrderDetail" asp-route-id="@o.OrderId" class="btn btn-outline-pawnect btn-sm">View order</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-droplet display-4 text-muted"></i>
                <h5 class="mt-3">No lab orders yet</h5>
                <p class="text-muted">Book a preventive health test to see orders and track status here.</p>
                <a asp-action="Index" class="btn btn-pawnect">Browse lab tests</a>
            </div>
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-pawnect btn-sm">Back to lab tests</a>
    </div>
</div>

<style>
    .vet-card-pawnect { border-radius: 12px; border: 1px solid var(--border); }
    .lab-status-badge { font-size: 0.7rem; }
</style>
