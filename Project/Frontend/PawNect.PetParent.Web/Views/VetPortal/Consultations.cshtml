@model List<VetAppointmentItemViewModel>
@{
    ViewData["Title"] = "Consultations";
}

<div class="vet-consultations-list">
    <h2 class="mb-2"><i class="bi bi-clipboard2-pulse me-2"></i>Consultations</h2>
    <p class="text-muted mb-4">Open a consult to view pet & parent details, add vitals, notes, diagnosis, prescription, and set next actions.</p>

    @if (Model != null && Model.Any())
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date & time</th>
                                <th>Pet</th>
                                <th>Parent</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model)
                            {
                                <tr>
                                    <td>@b.SlotDate @b.SlotTime</td>
                                    <td>@b.PetName</td>
                                    <td>@(b.ParentName ?? "—")</td>
                                    <td>@(b.ReasonForVisit ?? "—")</td>
                                    <td><span class="badge consult-status-badge">@b.Status</span></td>
                                    <td>
                                        <a asp-action="Consult" asp-route-appointmentId="@b.Id" class="btn btn-pawnect btn-sm">Open consult</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-clipboard2-pulse display-4 text-muted"></i>
                <h5 class="mt-3">No consultations yet</h5>
                <p class="text-muted mb-0">Appointments booked with you will appear here. Pet parents book via Find Vets.</p>
            </div>
        </div>
    }
</div>

<style>
    .consult-status-badge { font-size: 0.75rem; }
</style>
