@model VetDashboardViewModel
@{
    ViewData["Title"] = "Vet Dashboard";
}

<div class="vet-dashboard">
    <h2 class="mb-2"><i class="bi bi-hospital me-2"></i>Vet Dashboard</h2>
    <p class="text-muted mb-4">Today's and upcoming appointments.</p>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-teal-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-calendar-day me-2"></i>Today's appointments</h5>
                    <span class="badge bg-teal">@Model.TodayAppointments.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.TodayAppointments.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var a in Model.TodayAppointments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@a.PetName</strong> · @a.SlotTime<br />
                                        <small class="text-muted">@(a.ParentName ?? "—") · @(a.ReasonForVisit ?? "—")</small>
                                    </div>
                                    <a asp-action="Consult" asp-route-appointmentId="@a.Id" class="btn btn-pawnect btn-sm">Open consult</a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No appointments today.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-calendar-week me-2"></i>Upcoming appointments</h5>
                    <span class="badge bg-secondary">@Model.UpcomingAppointments.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.UpcomingAppointments.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var a in Model.UpcomingAppointments.Take(10))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@a.PetName</strong> · @a.SlotDate @a.SlotTime<br />
                                        <small class="text-muted">@(a.ParentName ?? "—")</small>
                                    </div>
                                    <a asp-action="Consult" asp-route-appointmentId="@a.Id" class="btn btn-outline-pawnect btn-sm">Open consult</a>
                                </li>
                            }
                        </ul>
                        @if (Model.UpcomingAppointments.Count > 10)
                        {
                            <p class="small text-muted p-2 mb-0">+ @(Model.UpcomingAppointments.Count - 10) more. <a asp-action="Consultations">View all</a></p>
                        }
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No upcoming appointments.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Consultations" class="btn btn-outline-pawnect"><i class="bi bi-clipboard2-pulse me-1"></i>All consultations</a>
        <a asp-action="OrderDiagnostics" class="btn btn-outline-secondary ms-2">Order diagnostics</a>
        <a asp-action="Reports" class="btn btn-outline-secondary ms-2">Reports</a>
        <a asp-action="MedicalGuidance" class="btn btn-outline-secondary ms-2">Medical guidance</a>
    </div>
</div>

<style>
    .bg-teal-light { background: rgba(22, 122, 119, 0.08); }
</style>
