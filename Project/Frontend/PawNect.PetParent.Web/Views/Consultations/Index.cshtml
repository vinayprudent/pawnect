@model List<BookingConfirmViewModel>
@{
    ViewData["Title"] = "My Consultations";
}

<div class="consultations-page">
    <h2 class="mb-4"><i class="bi bi-clipboard2-pulse me-2"></i>My Consultations</h2>
    <p class="text-muted mb-4">View consultation details, vitals, notes, diagnostics, and reports from your vet visits.</p>

    @if (Model != null && Model.Any())
    {
        <div class="consultation-list">
            @foreach (var b in Model)
            {
                <div class="card vet-card-pawnect mb-3">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col">
                                <h5 class="card-title mb-1">@b.VetName</h5>
                                <p class="card-text small text-muted mb-1">@b.ClinicName</p>
                                <p class="card-text small mb-1">
                                    <i class="bi bi-calendar3 me-1"></i>@b.SlotDate @b.SlotTime
                                    <span class="badge consult-status-badge ms-1">@b.Status</span>
                                </p>
                                <p class="card-text small mb-0">Pet: @b.PetName @if (!string.IsNullOrEmpty(b.ReasonForVisit)) { <span class="text-muted">· @b.ReasonForVisit</span> }</p>
                            </div>
                            <div class="col-auto">
                                <a asp-action="Details" asp-route-id="@b.AppointmentId" class="btn btn-pawnect btn-sm">
                                    <i class="bi bi-eye me-1"></i>View consultation
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-clipboard2-pulse display-4 text-muted"></i>
                <h5 class="mt-3">No consultations yet</h5>
                <p class="text-muted">Book an in-clinic appointment to start a consultation. After your visit, you’ll see details, vitals, notes, and reports here.</p>
                <a asp-controller="Vets" asp-action="Index" class="btn btn-pawnect me-2">Find Vets</a>
                <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-pawnect">My Appointments</a>
            </div>
        </div>
    }

    <div class="mt-4 pt-3 border-top">
        <p class="small text-muted mb-0">
            <strong>Status flow:</strong> Consult: Booked → In Progress → Completed → Closed. Diagnostics: Recommended → Sample Collected → Processing → Report Available → Reviewed.
        </p>
        <a asp-action="Demo" class="small">View sample consultation (demo)</a>
    </div>
</div>

<style>
    .vet-card-pawnect { border-radius: 12px; border: 1px solid var(--border); }
    .consult-status-badge { font-size: 0.7rem; }
</style>
