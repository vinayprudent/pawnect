@model RegisterVetViewModel
@{
    ViewData["Title"] = "Add Veterinary Clinic";
}
<h1>Add Veterinary Clinic</h1>
<div class="card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="ClinicName"></label>
            <input asp-for="ClinicName" />
        </div>
        <div class="form-group">
            <label asp-for="ContactFirstName"></label>
            <input asp-for="ContactFirstName" />
        </div>
        <div class="form-group">
            <label asp-for="ContactLastName"></label>
            <input asp-for="ContactLastName" />
        </div>
        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="email" />
        </div>
        <div class="form-group">
            <label asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" />
        </div>
        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" />
        </div>
        <div class="form-group">
            <label asp-for="City"></label>
            <input asp-for="City" />
        </div>
        <div class="form-group">
            <label asp-for="State"></label>
            <input asp-for="State" />
        </div>
        <div class="form-group">
            <label asp-for="ZipCode"></label>
            <input asp-for="ZipCode" />
        </div>
        <button type="submit" class="btn btn-primary">Register Clinic</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
